class Solution {
public:
    int compress(vector<char>& chars) {
        int ind = 0; // Pointer to write the compressed characters
        int n = chars.size();
        
        for (int i = 0; i < n; ) {
            char ch = chars[i];
            int count = 0;
            
            // Count the occurrences of the current character
            while (i < n && chars[i] == ch) {
                count++;
                i++;
            }
            
            // Step 1: Write the character
            chars[ind++] = ch;
            
            // Step 2: Write the count if it's greater than 1
            if (count > 1) {
                string str = to_string(count);
                for (char dig : str) {
                    chars[ind++] = dig; // Fixed syntax error here
                }
            }
        }
        
        return ind; // Fixed missing return statement
    }
};
