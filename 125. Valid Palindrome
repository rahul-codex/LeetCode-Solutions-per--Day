        bool isPalindrome(string s) {
            int st = 0, end = s.size() - 1;

            while (st < end) {
                // AGAR character alphanumeric NAHI hai, toh skip karein (!)
                if (!isalnum(s[st])) {
                    st++;
                    continue;
                }
                if (!isalnum(s[end])) {
                    end--;
                    continue;
                }

                // Dono valid characters ko compare karein
                if (tolower(s[st]) != tolower(s[end])) {
                    return false;
                }
                st++;
                end--;
            }
            return true;
        }
    };
