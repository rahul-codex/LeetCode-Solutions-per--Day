========================Beginner level 

class Solution {
public:
    bool isPowerOfThree(int n) {
        int m = 3;
        for (int i = 1; i < n; i++) {
            if (m == n) {
                return true;
            } else {
                m = m * 3;
            }
        }
        return false;
    }
};


==============================normal 

class Solution {
public:
    bool isPowerOfThree(int n) {
        if (n <= 0)
            return false;

        while (n % 3 == 0) {
            n /= 3;
       

        return n == 1;
    }
};
